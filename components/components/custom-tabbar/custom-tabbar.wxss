.custom-tabbar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(252, 249, 250, 0.95);
  border: 2rpx solid rgba(233, 226, 229, 0.95);
  border-radius: 28rpx;
  box-shadow: 0 14rpx 34rpx rgba(177, 167, 171, 0.14);
  z-index: 40;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8d7b82;
}

.tab-icon {
  font-size: 28rpx;
  line-height: 1.2;
}

.tab-text {
  margin-top: 4rpx;
  font-size: 20rpx;
}

.tab-item.active {
  color: #61b876;
  font-weight: 700;
}
