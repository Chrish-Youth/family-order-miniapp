<view class="menu-page">
  <view class="left-panel">
    <view class="category-title">菜单</view>

    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-item {{currentCategory === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="changeCategory"
    >
      <view class="category-text">{{item.name}}</view>
    </view>
  </view>

  <view class="right-panel">
    <view class="menu-header">
      <view class="menu-banner">
        <view class="menu-banner-title">今日推荐</view>
        <view class="menu-banner-desc">按需点餐，现做更新鲜</view>
      </view>
    </view>

    <block wx:for="{{dishList}}" wx:key="id">
      <view wx:if="{{item.category === currentCategory}}" class="dish-card">
        <view class="dish-img-wrap">
          <view class="dish-badge" wx:if="{{item.isHot}}">推荐</view>
          <view class="dish-img">{{item.name}}</view>
        </view>

        <view class="dish-info">
          <view class="dish-top">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-tag" wx:if="{{item.isHot}}">人气</view>
          </view>

          <view class="dish-desc">{{item.desc}}</view>

          <view class="dish-bottom">
            <view class="dish-price-wrap">
              <text class="price-symbol">￥</text>
              <text class="price-num">{{item.price}}</text>
            </view>

            <view class="stepper">
              <text class="btn" bindtap="minusCount" data-id="{{item.id}}">-</text>
              <text class="count">{{item.count}}</text>
              <text class="btn plus" bindtap="plusCount" data-id="{{item.id}}">+</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="cart-bar" bindtap="openCartPopup">
    <view class="cart-left">
      <view class="cart-icon">🛍</view>
      <view class="cart-info">
        <view class="cart-total">已选 {{totalCount}} 份</view>
        <view class="cart-price">合计：￥{{totalPrice}}</view>
      </view>
    </view>

    <button class="cart-btn" catchtap="goConfirm">去下单</button>
  </view>

  <view
    wx:if="{{showCartPopup}}"
    class="cart-mask {{popupClosing ? 'cart-mask-hide' : 'cart-mask-show'}}"
    bindtap="closeCartPopup"
  ></view>

  <view
    wx:if="{{showCartPopup}}"
    class="cart-popup {{popupClosing ? 'cart-popup-hide' : 'cart-popup-show'}}"
  >
    <view class="cart-popup-header">
      <view class="cart-popup-title">购物车</view>
      <view class="cart-clear" bindtap="clearCart">清空</view>
    </view>

    <scroll-view class="cart-popup-list" scroll-y="true">
      <view class="cart-popup-item" wx:for="{{cartList}}" wx:key="id">
        <view class="cart-popup-info">
          <view class="cart-popup-name">{{item.name}}</view>
          <view class="cart-popup-price">￥{{item.price}}</view>
        </view>

        <view class="stepper">
          <text class="btn" bindtap="minusCount" data-id="{{item.id}}">-</text>
          <text class="count">{{item.count}}</text>
          <text class="btn plus" bindtap="plusCount" data-id="{{item.id}}">+</text>
        </view>
      </view>
    </scroll-view>

    <view class="cart-popup-footer">
      <view class="cart-popup-total">
        合计：<text class="popup-total-price">￥{{totalPrice}}</text>
      </view>
      <button class="cart-popup-btn" catchtap="goConfirm">去下单</button>
    </view>
  </view>

  <view
    wx:if="{{flyBall.show}}"
    class="fly-ball"
    style="left: {{flyBall.x}}px; top: {{flyBall.y}}px;"
    animation="{{flyBall.animationData}}"
  ></view>
</view>