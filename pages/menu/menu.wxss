.menu-page {
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

/* 左侧分类栏 */
.left-panel {
  width: 150rpx;
  background: #f3efe8;
  border-right: 1rpx solid #ebe5db;
  padding-top: 18rpx;
}

.category-title {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 16rpx;
}

.category-item {
  position: relative;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 28rpx;
}

.category-text {
  line-height: 1.3;
}

.category-item.active {
  background: #fff;
  color: #d9363e;
  font-weight: 700;
}

.category-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 42rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: #e53935;
}

/* 右侧内容区 */
.right-panel {
  flex: 1;
  padding: 18rpx 18rpx 130rpx;
  overflow-y: auto;
}

.menu-header {
  margin-bottom: 18rpx;
}

.menu-banner {
  background: linear-gradient(135deg, #fff2f0, #fff9f7);
  border: 1rpx solid #ffe0db;
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
}

.menu-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #d9363e;
  margin-bottom: 6rpx;
}

.menu-banner-desc {
  font-size: 24rpx;
  color: #999;
}

/* 菜品卡片 */
.dish-card {
  display: flex;
  gap: 18rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.dish-img-wrap {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.dish-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff1e6, #ffe4d6);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 12rpx;
  box-sizing: border-box;
  color: #d94841;
  font-size: 24rpx;
  font-weight: 700;
}

.dish-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  z-index: 2;
  background: #e53935;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  line-height: 1;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 150rpx;
}

.dish-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.dish-tag {
  flex-shrink: 0;
  background: #fff1f0;
  color: #d9363e;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.dish-desc {
  font-size: 23rpx;
  color: #999;
  line-height: 1.5;
  margin: 8rpx 0 10rpx;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dish-price-wrap {
  display: flex;
  align-items: baseline;
  color: #e53935;
  font-weight: 700;
}

.price-symbol {
  font-size: 22rpx;
  margin-right: 2rpx;
}

.price-num {
  font-size: 34rpx;
}

/* 加减按钮 */
.stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f2f2f2;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.btn.plus {
  background: linear-gradient(135deg, #ff8c7a, #e53935);
  color: #fff;
}

.count {
  min-width: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
}

/* 底部购物车 */
.cart-bar {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  height: 92rpx;
  border-radius: 18rpx;
  background: rgba(40, 40, 40, 0.96);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  color: #fff;
  z-index: 20;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.22);
}

.cart-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.cart-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.cart-info {
  display: flex;
  flex-direction: column;
}

.cart-total {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

.cart-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.cart-btn {
  height: 62rpx;
  line-height: 62rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff8c7a, #e53935);
  color: #fff;
  border: none;
  font-size: 26rpx;
  font-weight: 700;
}

/* 遮罩 */
.cart-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 30;
}

.cart-mask-show {
  animation: maskFadeIn 0.25s ease forwards;
}

.cart-mask-hide {
  animation: maskFadeOut 0.25s ease forwards;
}

/* 弹窗 */
.cart-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 620rpx;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 31;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(100%);
}

.cart-popup-show {
  animation: popupSlideUp 0.28s ease forwards;
}

.cart-popup-hide {
  animation: popupSlideDown 0.25s ease forwards;
}

.cart-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 24rpx 18rpx;
  border-bottom: 1rpx solid #f3f3f3;
}

.cart-popup-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.cart-clear {
  font-size: 24rpx;
  color: #999;
}

.cart-popup-list {
  flex: 1;
  padding: 0 24rpx;
}

.cart-popup-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-popup-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cart-popup-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.cart-popup-price {
  font-size: 26rpx;
  color: #e53935;
  font-weight: 700;
}

.cart-popup-footer {
  height: 110rpx;
  padding: 0 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f3f3f3;
  background: #fff;
}

.cart-popup-total {
  font-size: 28rpx;
  color: #333;
}

.popup-total-price {
  color: #e53935;
  font-weight: 700;
}

.cart-popup-btn {
  background: linear-gradient(135deg, #ff8c7a, #e53935);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
}

/* 小球飞入 */
.fly-ball {
  position: fixed;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8c7a, #e53935);
  z-index: 50;
  box-shadow: 0 6rpx 12rpx rgba(229, 57, 53, 0.28);
  pointer-events: none;
}

/* 动画 */
@keyframes popupSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes popupSlideDown {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(100%);
  }
}

@keyframes maskFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes maskFadeOut {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}